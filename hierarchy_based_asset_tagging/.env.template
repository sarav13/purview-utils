# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.

TENANT_ID=xxxxxxxxxxxxx
CLIENT_ID=xxxxxxxxxxxxx
CLIENT_SECRET=xxxxxxxxxxxxx

PURVIEW_ACCOUNT=your-purview-account-name

#From where you want to traverse
#ROOT_COLLECTION_ID=your-root-collection-system-id 

# Number of assets per search page
SEARCH_PAGE_SIZE=100

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Number of retry attempts on transient failures
RETRY_ATTEMPTS=3

# Exponential back-off base in seconds (sleep = base^attempt)
RETRY_BACKOFF=2.0

# Set to true to skip labelling assets in any collection that has child collections.
# Only leaf (childless) collections will have their assets labelled.
SKIP_PARENT_COLLECTIONS=true

# Set to true to include the root collection's name as the first segment of
# every generated label. When false (default), the root is excluded so labels
# stay concise - e.g. 'client-silver' instead of 'fabric-client-silver'.
# Mirror of SKIP_PARENT_COLLECTIONS: both are traversal/label scope flags.
INCLUDE_ROOT_IN_LABEL=false
